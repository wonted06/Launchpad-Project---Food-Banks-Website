<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | Health Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Bebas Neue', 'sans-serif'],
            sans: ['Barlow', 'sans-serif'],
          },
          colors: {
            nike: {
              black:  '#111111',
              orange: '#FA5400',
              gray:   '#757575',
              light:  '#F5F5F5',
            }
          }
        }
      }
    }
  </script>
  <script src="./js/dashboard.js" defer></script>
</head>
<body class="bg-nike-light font-sans">
  <!-- Navigation -->
  <nav class="bg-nike-black border-b border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/" class="flex items-center gap-2 text-2xl font-display uppercase tracking-widest text-white hover:text-nike-orange">
          Health Tracker
        </a>
        <div class="flex items-center gap-6">
          <a href="/health" class="text-sm font-medium text-white hover:text-nike-orange transition">Health Entries</a>
          <a href="/suggestions" class="text-sm font-medium text-white hover:text-nike-orange transition">AI Suggestions</a>
          <a href="/analytics" class="text-sm font-medium text-white hover:text-nike-orange transition">Analytics</a>
          <a href="/community" class="text-sm font-medium text-white hover:text-nike-orange transition">Community</a>
          <div class="flex items-center gap-4 pl-4 border-l border-gray-700">

            <a href="/logout" class="px-3 py-1 bg-nike-orange hover:bg-orange-600 text-white text-sm font-medium rounded transition">
              Logout
            </a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Welcome Section -->
    <div class="mb-12">
      <h1 class="text-5xl font-display uppercase tracking-widest text-nike-black mb-2">Welcome to Your Health Dashboard</h1>
      <p class="text-base text-nike-gray font-sans">Track your health, get AI-powered insights, and connect with others</p>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white rounded-lg shadow p-6 border-l-4 border-nike-orange">
        <h3 class="text-nike-gray text-sm font-medium mb-2">Total Entries</h3>
        <p class="text-3xl font-display text-nike-black" id="totalEntriesCounter">0</p>
        <p class="text-xs text-nike-gray mt-2">Health Logs created</p>
      </div>

      <div class="bg-white rounded-lg shadow p-6 border-l-4 border-nike-orange">
        <h3 class="text-nike-gray text-sm font-medium mb-2">This Week</h3>
        <p class="text-3xl font-display text-nike-black" id="thisWeekCounter">0</p>
        <p class="text-xs text-nike-gray mt-2">Health logs tracked</p>
      </div>

      <div class="bg-white rounded-lg shadow p-6 border-l-4 border-nike-orange">
        <h3 class="text-nike-gray text-sm font-medium mb-2">AI Suggestions</h3>
        <p class="text-3xl font-display text-nike-black">0</p>
        <p class="text-xs text-nike-gray mt-2">diet recommendations</p>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Health Entries Card -->
      <a href="/health" class="group">
        <div class="bg-white rounded-lg shadow hover:shadow-lg transition p-6 cursor-pointer">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-nike-light rounded-lg flex items-center justify-center text-2xl">
              +
            </div>
            <h3 class="ml-4 text-xl font-display uppercase tracking-wide text-nike-black group-hover:text-nike-orange transition">Health Entries</h3>
          </div>
          <p class="text-nike-gray">Log your diet, activity, and wellness data</p>

        </div>
      </a>

      <!-- AI Suggestions Card -->
      <a href="/suggestions" class="group">
        <div class="bg-white rounded-lg shadow hover:shadow-lg transition p-6 cursor-pointer">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-nike-light rounded-lg flex items-center justify-center text-2xl">
              ?
            </div>
            <h3 class="ml-4 text-xl font-display uppercase tracking-wide text-nike-black group-hover:text-nike-orange transition">Suggestions</h3>
          </div>
          <p class="text-nike-gray">Get personalized diet and exercise recommendations</p>

        </div>
      </a>

      <!-- Community Chat Card -->
      <a href="/community" class="group">
        <div class="bg-white rounded-lg shadow hover:shadow-lg transition p-6 cursor-pointer">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-nike-light rounded-lg flex items-center justify-center text-2xl">
              {xyz}
            </div>
            <h3 class="ml-4 text-xl font-display uppercase tracking-wide text-nike-black group-hover:text-nike-orange transition">Community Chat</h3>
          </div>
          <p class="text-nike-gray">Connect with other health tracker users</p>

        </div>
      </a>

      <!-- Analytics Card -->
      <a href="/analytics" class="group">
        <div class="bg-white rounded-lg shadow hover:shadow-lg transition p-6 cursor-pointer">
          <div class="flex items-center mb-4">
            <div class="w-12 h-12 bg-nike-light rounded-lg flex items-center justify-center text-2xl">
              [123]
            </div>
            <h3 class="ml-4 text-xl font-display uppercase tracking-wide text-nike-black group-hover:text-nike-orange transition">Analytics</h3>
          </div>
          <p class="text-nike-gray">View trends and insights about your health</p>

        </div>
      </a>
    </div>


  </main>

  <!-- Footer -->
  <footer class="bg-gray-100 border-t border-gray-200 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center text-sm text-nike-gray">
      <p>&copy; 2026 Health Tracker - CMP-5012B Course Project | Team 299</p>
      <p class="mt-2 text-xs">Built with Node.js, Express, EJS, Tailwind CSS & PostgreSQL</p>
    </div>
  </footer>
    <!-- <script>
    const storedUser = JSON.parse(localStorage.getItem('loggedInUser')); //stores the text saved when the user logs in to use for the display
    if (storedUser && storedUser.name) {
      document.getElementById('welcomeName').textContent = storedUser.name; //updates the welcome name text to the user name
    }
  </script> -->
</body>
</html>
