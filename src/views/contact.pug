extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 #{t('contact.hero.title')}
      p.page-subtitle #{t('contact.hero.subtitle')}

  section.section
    .container
      .contact-layout
        .contact-info
          h2 #{t('contact.section.title')}
          p We're here to help. Reach out with any questions, concerns, or feedback.

          .info-row
            i.fa-solid.fa-map-pin
            div
              strong #{t('contact.label.address')}
              p Feed Birmingham, c/o Birmingham City Council, Victoria Square, Birmingham, B1 1BB

          .info-row
            i.fa-solid.fa-phone
            div
              strong #{t('contact.label.phone')}
              p 0121 000 0000

          .info-row
            i.fa-solid.fa-envelope
            div
              strong #{t('contact.label.email')}
              p hello@feedbirmingham.org

          .info-row
            i.fa-regular.fa-clock
            div
              strong #{t('contact.label.hours')}
              p Monday – Friday: 09:00 – 17:00

        .contact-form-wrap
          h2 #{t('contact.form.title')}
          if success
            .success-box
              i.fa-solid.fa-circle-check
              |  #{t('contact.form.success')}
          form.form(action='/contact', method='POST')
            .form-row
              .form-group
                label(for='c-name') #{t('contact.form.name')}
                input#c-name(type='text', name='name', placeholder='Your name', required)
              .form-group
                label(for='c-email') #{t('contact.form.email')}
                input#c-email(type='email', name='email', placeholder='your@email.com', required)

            .form-group
              label(for='c-subject') #{t('contact.form.subject')}
              select#c-subject(name='subject')
                option(value='') Select a subject
                option #{t('contact.subject.general')}
                option #{t('contact.subject.support')}
                option #{t('contact.subject.delivery')}
                option #{t('contact.subject.volunteer')}
                option #{t('contact.subject.feedback')}
                option #{t('contact.subject.other')}

            .form-group
              label(for='c-message') #{t('contact.form.message')}
              textarea#c-message(name='message', rows='5', placeholder='Write your message here...', required)

            button.btn.btn-green(type='submit')
              i.fa-solid.fa-paper-plane
              |  #{t('contact.form.send')}
              if error
                .error-box
                  i.fa-solid.fa-circle-exclamation
                  |  #{error}
                  input#c-name(type='text', name='name', value=form.name || '', placeholder='Your name', required)
                  input#c-email(type='email', name='email', value=form.email || '', placeholder='your@email.com', required)
                  textarea#c-message(name='message', rows='5', placeholder='Write your message here...', required)= form.message || ''
