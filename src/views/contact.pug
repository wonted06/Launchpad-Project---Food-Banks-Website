extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 #{t('contact.hero.title')}
      p.page-subtitle #{t('contact.hero.subtitle')}

  section.section
    .container
      .contact-layout
        .contact-info
          h2 #{t('contact.section.title')}
          p We're here to help. Reach out with any questions, concerns, or feedback.

          .info-row
            i.fa-solid.fa-map-pin
            div
              strong #{t('contact.label.address')}
              p Feed Birmingham, c/o Birmingham City Council, Victoria Square, Birmingham, B1 1BB

          .info-row
            i.fa-solid.fa-phone
            div
              strong #{t('contact.label.phone')}
              p 0121 000 0000

          .info-row
            i.fa-solid.fa-envelope
            div
              strong #{t('contact.label.email')}
              p hello@feedbirmingham.org

          .info-row
            i.fa-regular.fa-clock
            div
              strong #{t('contact.label.hours')}
              p Monday – Friday: 09:00 – 17:00

        .contact-form-wrap
          h2 #{t('contact.form.title')}

          if success
            .success-box
              i.fa-solid.fa-circle-check
              |  #{t('contact.form.success')}

          if error
            .error-box
              i.fa-solid.fa-circle-exclamation
              |  #{error}

          form.form(action='/contact', method='POST')
            .form-row
              .form-group
                label(for='c-name') #{t('contact.form.name')}
                input#c-name(type='text', name='name', value=form && form.name ? form.name : '', placeholder='Your name', required)
              .form-group
                label(for='c-email') #{t('contact.form.email')}
                input#c-email(type='email', name='email', value=form && form.email ? form.email : '', placeholder='your@email.com', required)

            .form-group
              label(for='c-subject') #{t('contact.form.subject')}
              select#c-subject(name='subject')
                option(value='') Select a subject
                option(value='General Enquiry', selected=form && form.subject==='General Enquiry') #{t('contact.subject.general')}
                option(value='Food Bank Support', selected=form && form.subject==='Food Bank Support') #{t('contact.subject.support')}
                option(value='Delivery Request', selected=form && form.subject==='Delivery Request') #{t('contact.subject.delivery')}
                option(value='Volunteer', selected=form && form.subject==='Volunteer') #{t('contact.subject.volunteer')}
                option(value='Feedback', selected=form && form.subject==='Feedback') #{t('contact.subject.feedback')}
                option(value='Other', selected=form && form.subject==='Other') #{t('contact.subject.other')}

            .form-group
              label(for='c-message') #{t('contact.form.message')}
              textarea#c-message(name='message', rows='5', placeholder='Write your message here...', required)= form && form.message ? form.message : ''

            button.btn.btn-green(type='submit')
              i.fa-solid.fa-paper-plane
              |  #{t('contact.form.send')}

  //- ── FAQ Section ──────────────────────────────────────────────
  section.section.section--faq
    .container
      .faq-section
        .faq-header
          h2
            i.fa-solid.fa-circle-question
            |  Frequently Asked Questions
          p.faq-subhead Find quick answers to common questions about our services. Can't find what you're looking for? Use the contact form above.

        .faq-search-wrap
          i.fa-solid.fa-magnifying-glass
          input#faq-search(type='text', placeholder='Search FAQs…', autocomplete='off')

        .faq-list#faq-list

          .faq-item
            button.faq-question(type='button')
              span How do I get help from a food bank?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p You'll usually need a referral from a frontline professional such as a GP, social worker, or school. Some of our food banks also accept self-referrals. Contact us or visit the Locations page to find your nearest food bank and get started.

          .faq-item
            button.faq-question(type='button')
              span What items will I receive in a food parcel?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Food parcels typically contain non-perishable items such as tinned vegetables, pasta, rice, cereal, tinned meat or fish, and soup. We also include tea, coffee, and toiletries where possible, and try to accommodate dietary requirements.

          .faq-item
            button.faq-question(type='button')
              span How often can I use a food bank?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Food bank vouchers typically cover a 3-day emergency supply. Most people can use the service up to three times per referral, though this varies by organisation. Speak to the referring professional or contact us for guidance specific to your situation.

          .faq-item
            button.faq-question(type='button')
              span What are the food bank opening times?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Opening times vary by location. Please visit the Locations page and click "Details" on your nearest food bank to see its specific opening hours.

          .faq-item
            button.faq-question(type='button')
              span Can I donate food to Feed Birmingham?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Yes — we welcome donations of non-perishable, in-date food items with at least 3 months until their use-by date. Visit the Donate page for a list of most-needed items and local drop-off points across Birmingham.

          .faq-item
            button.faq-question(type='button')
              span Is there a food delivery service?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Yes! We offer a free delivery service for Birmingham residents who have difficulty travelling due to mobility issues, disability, or other accessibility needs. Visit the Delivery page to submit a request.

          .faq-item
            button.faq-question(type='button')
              span What if I have dietary requirements or allergies?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Please let us know about any allergies or dietary needs when you visit or when your referral is made. We will do our best to tailor your food parcel and exclude any items that are not suitable for you.

          .faq-item
            button.faq-question(type='button')
              span Are there free hot meals available?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Yes — free hot meals are served at several food banks across Birmingham each week. Check the Hot Meal Schedule page for this week's locations, times, and menus. No referral is needed — just turn up.

          .faq-item
            button.faq-question(type='button')
              span How can I volunteer with Feed Birmingham?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p We'd love to have you! Visit the Donate page and select "Volunteer" to complete a short application. We have roles in sorting and packing food, delivering parcels, and supporting community events across Birmingham.

          .faq-item
            button.faq-question(type='button')
              span Is my personal information kept private?
              i.fa-solid.fa-chevron-down
            .faq-answer
              p Yes. Any information you share with us is handled in strict confidence and used solely to provide the support you need. We do not share your details with third parties without your explicit consent.

  script.
    // ── FAQ accordion ──────────────────────────────────────────
    document.querySelectorAll('.faq-question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item   = btn.closest('.faq-item');
        var isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
        if (!isOpen) item.classList.add('open');
      });
    });

    // ── FAQ search ─────────────────────────────────────────────
    var faqSearch = document.getElementById('faq-search');
    if (faqSearch) {
      faqSearch.addEventListener('input', function() {
        var q = faqSearch.value.trim().toLowerCase();
        document.querySelectorAll('.faq-item').forEach(function(item) {
          var text = item.textContent.toLowerCase();
          item.style.display = (!q || text.includes(q)) ? '' : 'none';
        });
      });
    }
