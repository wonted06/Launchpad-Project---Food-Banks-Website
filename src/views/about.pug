extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 About Us
      p.page-subtitle Connecting Birmingham communities with the food support they need.

  section.section
    .container
      .about-layout
        .about-mission
          h2 Our Mission
          p
            | Feed Birmingham is a free web-based service designed to connect
            | Birmingham residents with local food banks, hot meal services, and
            | food deliveries. We exist to ensure no one in Birmingham goes hungry.
          p
            | Our platform provides reliable, up-to-date information about food
            | bank locations, opening hours, stock levels, and delivery services —
            | all in one accessible place.

        .about-image
          img(src='/images/hero.png', alt='Volunteers packing food boxes')

  section.section.section--green
    .container
      h2.section-title Sustainability
      .sustainability-grid
        .sus-card
          i.fa-solid.fa-leaf
          h3 Reducing Food Waste
          p
            | By connecting surplus food with those who need it most,
            | we help reduce food waste across Birmingham.
        .sus-card
          i.fa-solid.fa-route
          h3 Precise Directions
          p
            | Our location service provides precise directions to your nearest
            | food bank, minimising unnecessary travel and carbon emissions.
        .sus-card
          i.fa-solid.fa-wheelchair
          h3 Accessible Delivery
          p
            | Deliveries are tailored for residents with accessibility needs,
            | reaching a wider range of people while keeping a low carbon footprint.
        .sus-card
          i.fa-solid.fa-users
          h3 Community First
          p
            | We work with local food banks, volunteers, and community organisations
            | to build a stronger, more food-secure Birmingham.

  //- ── MEET THE TEAM ─────────────────────────────────────────
  section.section.team-section
    .container
      h2.section-title Meet the Team
      p.section-subtitle The people behind Feed Birmingham.

      .team-grid
        //- Card 1
        .team-card(data-index='0')
          .team-photo-wrap
            img.team-photo(src='/images/team/member1.jpg', alt='Team Member', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Team Member 1
            p.team-role Role / Responsibility
          .team-hover
            h4 Team Member 1
            p Your short contribution summary here — what you built or worked on for this project.
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 2
        .team-card(data-index='1')
          .team-photo-wrap
            img.team-photo(src='/images/team/member2.jpg', alt='Team Member', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Team Member 2
            p.team-role Role / Responsibility
          .team-hover
            h4 Team Member 2
            p Your short contribution summary here — what you built or worked on for this project.

        //- Card 3
        .team-card(data-index='2')
          .team-photo-wrap
            img.team-photo(src='/images/team/member3.jpg', alt='Team Member', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Team Member 3
            p.team-role Role / Responsibility
          .team-hover
            h4 Team Member 3
            p Your short contribution summary here — what you built or worked on for this project.

        //- Card 4
        .team-card(data-index='3')
          .team-photo-wrap
            img.team-photo(src='/images/team/member4.jpg', alt='Team Member', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Team Member 4
            p.team-role Role / Responsibility
          .team-hover
            h4 Team Member 4
            p Your short contribution summary here — what you built or worked on for this project.

        //- Card 5
        .team-card(data-index='4')
          .team-photo-wrap
            img.team-photo(src='/images/team/member5.jpg', alt='Team Member', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Team Member 5
            p.team-role Role / Responsibility
          .team-hover
            h4 Team Member 5
            p Your short contribution summary here — what you built or worked on for this project.

        //- Card 6
        .team-card(data-index='5')
          .team-photo-wrap
            img.team-photo(src='/images/team/member6.jpg', alt='Team Member', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Team Member 6
            p.team-role Role / Responsibility
          .team-hover
            h4 Team Member 6
            p Your short contribution summary here — what you built or worked on for this project.

  //- ── TEAM MODAL ─────────────────────────────────────────────
  .team-modal-backdrop#teamModalBackdrop
    .team-modal#teamModal
      button.team-modal-close#teamModalClose(aria-label='Close')
        i.fa-solid.fa-xmark
      .team-modal-body
        .team-modal-photo-wrap
          img#teamModalPhoto(src='', alt='')
        .team-modal-text
          h2#teamModalName
          p.team-modal-role#teamModalRole
          p.team-modal-intro#teamModalIntro
          .team-modal-contribution
            h4
              i.fa-solid.fa-star
              |  Contribution
            p#teamModalContribution

  section.section
    .container
      h2.section-title Our Values
      .values-list
        .value-item
          .value-number 01
          .value-text
            h3 Accessibility
            p Everyone deserves access to food, regardless of circumstance or ability.
        .value-item
          .value-number 02
          .value-text
            h3 Community
            p We believe in the power of local communities to support one another.
        .value-item
          .value-number 03
          .value-text
            h3 Dignity
            p We provide support with compassion and respect for every individual.
        .value-item
          .value-number 04
          .value-text
            h3 Sustainability
            p We aim to reduce food waste and environmental impact in everything we do.

  script.
    // ── Team member data ────────────────────────────────────────
    // Fill in your own names, roles, intros, contributions, and photo paths here
    const teamMembers = [
      {
        name: 'Team Member 1',
        role: 'Role / Responsibility',
        photo: '/images/team/member1.jpg',
        intro: 'A brief introduction about this team member — their background, skills, or course.',
        contribution: 'Describe what this person built or worked on for this project. For example: designed and implemented the Locations page, set up the database schema, built the delivery tracking feature, etc.'
      },
      {
        name: 'Team Member 2',
        role: 'Role / Responsibility',
        photo: '/images/team/member2.jpg',
        intro: 'A brief introduction about this team member — their background, skills, or course.',
        contribution: 'Describe what this person built or worked on for this project.'
      },
      {
        name: 'Team Member 3',
        role: 'Role / Responsibility',
        photo: '/images/team/member3.jpg',
        intro: 'A brief introduction about this team member — their background, skills, or course.',
        contribution: 'Describe what this person built or worked on for this project.'
      },
      {
        name: 'Team Member 4',
        role: 'Role / Responsibility',
        photo: '/images/team/member4.jpg',
        intro: 'A brief introduction about this team member — their background, skills, or course.',
        contribution: 'Describe what this person built or worked on for this project.'
      },
      {
        name: 'Team Member 5',
        role: 'Role / Responsibility',
        photo: '/images/team/member5.jpg',
        intro: 'A brief introduction about this team member — their background, skills, or course.',
        contribution: 'Describe what this person built or worked on for this project.'
      },
      {
        name: 'Team Member 6',
        role: 'Role / Responsibility',
        photo: '/images/team/member6.jpg',
        intro: 'A brief introduction about this team member — their background, skills, or course.',
        contribution: 'Describe what this person built or worked on for this project.'
      }
    ];

    // ── Modal logic ─────────────────────────────────────────────
    const backdrop = document.getElementById('teamModalBackdrop');
    const modal    = document.getElementById('teamModal');
    const closeBtn = document.getElementById('teamModalClose');
    const mPhoto   = document.getElementById('teamModalPhoto');
    const mName    = document.getElementById('teamModalName');
    const mRole    = document.getElementById('teamModalRole');
    const mIntro   = document.getElementById('teamModalIntro');
    const mContrib = document.getElementById('teamModalContribution');

    function openModal(index) {
      const m = teamMembers[index];
      mPhoto.src   = m.photo;
      mPhoto.onerror = () => { mPhoto.src = '/images/team/placeholder.png'; };
      mPhoto.alt   = m.name;
      mName.textContent    = m.name;
      mRole.textContent    = m.role;
      mIntro.textContent   = m.intro;
      mContrib.textContent = m.contribution;
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.team-card').forEach(card => {
      card.addEventListener('click', () => openModal(+card.dataset.index));
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', e => {
      if (e.target === backdrop) closeModal();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });
