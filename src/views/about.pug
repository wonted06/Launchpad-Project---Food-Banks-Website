extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 #{t('about.hero.title')}
      p.page-subtitle #{t('about.hero.subtitle')}

  section.section
    .container
      .about-layout
        .about-mission
          h2 #{t('about.mission.title')}
          p
            | Feed Birmingham is a free web-based service designed to connect
            | Birmingham residents with local food banks, hot meal services, and
            | food deliveries. We exist to ensure no one in Birmingham goes hungry.
          p
            | Our platform provides reliable, up-to-date information about food
            | bank locations, opening hours, stock levels, and delivery services —
            | all in one accessible place.

        .about-image
          img(src='/images/about-volunteers.jpg', alt='Volunteers packing food boxes')

  section.section.section--green
    .container
      h2.section-title Sustainability
      .sustainability-grid
        .sus-card
          i.fa-solid.fa-leaf
          h3 Reducing Food Waste
          p
            | By connecting surplus food with those who need it most,
            | we help reduce food waste across Birmingham.
        .sus-card
          i.fa-solid.fa-route
          h3 Precise Directions
          p
            | Our location service provides precise directions to your nearest
            | food bank, minimising unnecessary travel and carbon emissions.
        .sus-card
          i.fa-solid.fa-wheelchair
          h3 Accessible Delivery
          p
            | Deliveries are tailored for residents with accessibility needs,
            | reaching a wider range of people while keeping a low carbon footprint.
        .sus-card
          i.fa-solid.fa-users
          h3 Community First
          p
            | We work with local food banks, volunteers, and community organisations
            | to build a stronger, more food-secure Birmingham.

  //- ── MEET THE TEAM ─────────────────────────────────────────
  section.section.team-section
    .container
      h2.section-title Meet the Team
      p.section-subtitle The people behind Feed Birmingham.

      .team-grid
        //- Card 1 — Kurt Canillas
        .team-card(data-index='0')
          .team-photo-wrap
            img.team-photo(src='/images/team/kurt-canillas.png', alt='Kurt Canillas', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Kurt Canillas
            p.team-role Developer and Designer 
          .team-hover
            h4 Kurt Canillas
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 2 — Harshita Chavali
        .team-card(data-index='1')
          .team-photo-wrap
            img.team-photo(src='/images/team/harshita-chavali.png', alt='Harshita Chavali', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Harshita Chavali
            p.team-role Documentation and Security Developer
          .team-hover
            h4 Harshita Chavali
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 3 — Kimi Tang
        .team-card(data-index='2')
          .team-photo-wrap
            img.team-photo(src='/images/team/kimi-tang.png', alt='Kimi Tang', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Kimi Tang
            p.team-role Developer
          .team-hover
            h4 Kimi Tang
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 4 — Eldridge Pacifico
        .team-card(data-index='3')
          .team-photo-wrap
            img.team-photo(src='/images/team/eldridge-pacifico.png', alt='Eldridge Pacifico', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Eldridge Pacifico
            p.team-role Developer
          .team-hover
            h4 Eldridge Pacifico
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 5 — Saira Abedi
        .team-card(data-index='4')
          .team-photo-wrap
            img.team-photo(src='/images/team/saira-abedi.png', alt='Saira Abedi', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Saira Abedi
            p.team-role Documentation and Security Developer
          .team-hover
            h4 Saira Abedi
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 6 — Sienna Casule
        .team-card(data-index='5')
          .team-photo-wrap
            img.team-photo(src='/images/team/sienna-casule.png', alt='Sienna Casule', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Sienna Casule
            p.team-role Documentation and Security Developer
          .team-hover
            h4 Sienna Casule
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

  //- ── TEAM MODAL ─────────────────────────────────────────────
  .team-modal-backdrop#teamModalBackdrop
    .team-modal#teamModal
      button.team-modal-close#teamModalClose(aria-label='Close')
        i.fa-solid.fa-xmark
      .team-modal-body
        .team-modal-photo-wrap
          img#teamModalPhoto(src='', alt='')
        .team-modal-text
          h2#teamModalName
          p.team-modal-role#teamModalRole
          p.team-modal-intro#teamModalIntro
          .team-modal-contribution
            h4
              i.fa-solid.fa-star
              |  Contribution
            p#teamModalContribution

  section.section
    .container
      h2.section-title Our Values
      .values-list
        .value-item
          .value-number 01
          .value-text
            h3 Accessibility
            p Everyone deserves access to food, regardless of circumstance or ability.
        .value-item
          .value-number 02
          .value-text
            h3 Community
            p We believe in the power of local communities to support one another.
        .value-item
          .value-number 03
          .value-text
            h3 Dignity
            p We provide support with compassion and respect for every individual.
        .value-item
          .value-number 04
          .value-text
            h3 Sustainability
            p We aim to reduce food waste and environmental impact in everything we do.

  script.
    // ── Team member data ────────────────────────────────────────
    // Fill in your own names, roles, intros, contributions, and photo paths here
    const teamMembers = [
      {
        name: 'Kurt Canillas',
        role: 'Developer & Designer',
        photo: '/images/team/kurt-canillas.png',
        intro: 'Computer Science student at the University of East Anglia with a passion for web development and user-centred design. I enjoy creating intuitive, accessible digital experiences that solve real-world problems and make a positive impact on communities.',
        contribution: 'Led the overall architecture and development of the Feed Birmingham platform. Created the overall frontend structure of the whole wbesite. Built the Locations page with interactive Leaflet map, implemented the postcode search with live radius filtering, and set up the Express/Pug project structure.'
      },
      {
        name: 'Harshita Chavali',
        role: 'Documentation & Security Developer',
        photo: '/images/team/harshita-chavali.png',
        intro: 'Harshita Chavali is a second year computing science student . Within the project team, she was responsible for supporting both the design and the security aspects of the website , while ensuring that the application was user- friendly, accessible and aligned with the project requirements. Her role was a security developer with Saira and Sienna and documentation as well as maintaining user experience.',
        contribution: 'Harshita contributed to the development and palnning of the project by designing several key wireframes including  the : Login,Register,About Us, Feedback, Settings, and Locations pages. She was responsible for  iplementing security features to improve the safety and reliability of the application such as .gitignore,express rate limit express validator and helmet. In addition, she created user personas, user stories, project risk assessments, and user testing parameters to support the design and evaluation process. Harshita also developed the project mission statement and contributed to the overall design and structure of the final presentation, helping to communicate the projects objectives, development process, and outcomes effectively.'
      },
      {
        name: 'Kimi Tang',
        role: 'Developer',
        photo: '/images/team/kimi-tang.png',
        intro: 'Computer Science student at the University of East Anglia. Enthusiastic about database design and back-end development for data-driven applications.',
        contribution: 'Worked on the database schema and PostgreSQL for the Inventory management system, including designing tables, writing SQL queries, and integrating with the Express backend. Also contributed to the creation '
      },
      {
        name: 'Eldridge Pacifico',
        role: 'Developer',
        photo: '/images/team/eldridge-pacifico.png',
        intro: 'Computer Science student at the University of East Anglia. Focused on building robust and scalable web applications with clean, maintainable code.',
        contribution: 'Developed the log in and registration system, including password hashing wiht bcrypt, session management with express-session, and input validation. Also contributed to the implementation of the user profile page and account management features.'
      },
      {
        name: 'Saira Abedi',
        role: 'Documentation & Security Developer',
        photo: '/images/team/saira-abedi.png',
        intro: 'Responsible for creating project documentation, designing website wireframes, helping to organise and track project tasks throughout the Agile development process, contributing to the final presentation, assisting with user testing and feedback, and implementing security measures to improve the websites security, reliability and user experience. ',
        contribution: 'Designed and created a large portion of the project documentation, including the Mission Statement, Stakeholders, Critical Success Factors, Sprint Plan, Gantt Chart, Agile Methodology, Use Case List and Use Case Diagram. Created wireframes for the Home, Donation, Sidebar Dropdown, Contact Us, Delivery, Profile, Inventory and Food Education pages, helping to define the structure and functionality of the website. Contributed to the design of the final presentation, ensuring the content was clear, visually appealing and easy to understand. Also took part in user testing, identifying issues, suggesting improvements and helping to ensure the website met the project requirements. In addition, implemented key security measures including Helmet for secure HTTP headers, Express Rate Limit to help protect against brute-force and DoS attacks, Express Validator for input validation, and .gitignore to prevent sensitive files from being exposed in the repository. '
      },
      {
        name: 'Sienna Casule',
        role: 'Documentation & Security Developer',
        photo: '/images/team/sienna-casule.png',
        intro: 'Responsible for developing and maintaining key project documentation, including the Moscow analysis and the functional and non-functional requirements specification. I collaborated with team members on system design activities, assisting with the creation of Entity Relationship Diagrams (ERDs) and contributing to the design and formatting of project presentations. Additionally, I worked alongside Saira and Harshita to implement security measures within the website.',
        contribution: 'My primary contribution was producing comprehensive project documentation that defined the systems requirements and prioritised features using the MoSCoW framework, providing a clear foundation for development. I supported the database design process by assisting Kimi with Entity Relationship Diagrams, helping to model the relationships between system entities and ensure data integrity. Furthermore, I contributed to the preparation of professional PowerPoint presentations used to communicate project progress and design decisions. On the technical side, I helped strengthen the websites security by implementing middleware and validation tools such as Helmet for securing HTTP headers, Express Rate Limit to protect against abuse and excessive requests, Express Validator for input validation and sanitisation, and configuring a .gitignore file to prevent sensitive or unnecessary files from being committed to version control. These contributions improved the projects security, maintainability, and overall quality.'
      }
    ];

    // ── Modal logic ─────────────────────────────────────────────
    const backdrop = document.getElementById('teamModalBackdrop');
    const modal    = document.getElementById('teamModal');
    const closeBtn = document.getElementById('teamModalClose');
    const mPhoto   = document.getElementById('teamModalPhoto');
    const mName    = document.getElementById('teamModalName');
    const mRole    = document.getElementById('teamModalRole');
    const mIntro   = document.getElementById('teamModalIntro');
    const mContrib = document.getElementById('teamModalContribution');

    function openModal(index) {
      const m = teamMembers[index];
      mPhoto.src   = m.photo;
      mPhoto.onerror = () => { mPhoto.src = '/images/team/placeholder.png'; };
      mPhoto.alt   = m.name;
      mName.textContent    = m.name;
      mRole.textContent    = m.role;
      mIntro.textContent   = m.intro;
      mContrib.textContent = m.contribution;
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.team-card').forEach(card => {
      card.addEventListener('click', () => openModal(+card.dataset.index));
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', e => {
      if (e.target === backdrop) closeModal();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });
