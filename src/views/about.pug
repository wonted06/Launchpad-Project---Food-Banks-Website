extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 #{t('about.hero.title')}
      p.page-subtitle #{t('about.hero.subtitle')}

  section.section
    .container
      .about-layout
        .about-mission
          h2 #{t('about.mission.title')}
          p
            | Feed Birmingham is a free web-based service designed to connect
            | Birmingham residents with local food banks, hot meal services, and
            | food deliveries. We exist to ensure no one in Birmingham goes hungry.
          p
            | Our platform provides reliable, up-to-date information about food
            | bank locations, opening hours, stock levels, and delivery services —
            | all in one accessible place.

        .about-image
          img(src='/images/about-volunteers.jpg', alt='Volunteers packing food boxes')

  section.section.section--green
    .container
      h2.section-title Sustainability
      .sustainability-grid
        .sus-card
          i.fa-solid.fa-leaf
          h3 Reducing Food Waste
          p
            | By connecting surplus food with those who need it most,
            | we help reduce food waste across Birmingham.
        .sus-card
          i.fa-solid.fa-route
          h3 Precise Directions
          p
            | Our location service provides precise directions to your nearest
            | food bank, minimising unnecessary travel and carbon emissions.
        .sus-card
          i.fa-solid.fa-wheelchair
          h3 Accessible Delivery
          p
            | Deliveries are tailored for residents with accessibility needs,
            | reaching a wider range of people while keeping a low carbon footprint.
        .sus-card
          i.fa-solid.fa-users
          h3 Community First
          p
            | We work with local food banks, volunteers, and community organisations
            | to build a stronger, more food-secure Birmingham.

  //- ── MEET THE TEAM ─────────────────────────────────────────
  section.section.team-section
    .container
      h2.section-title Meet the Team
      p.section-subtitle The people behind Feed Birmingham.

      .team-grid
        //- Card 1 — Kurt Canillas
        .team-card(data-index='0')
          .team-photo-wrap
            img.team-photo(src='/images/team/kurt-canillas.png', alt='Kurt Canillas', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Kurt Canillas
            p.team-role Developer
          .team-hover
            h4 Kurt Canillas
            p.team-hover-hint
              i.fa-solid.fa-up-right-and-down-left-from-center
              |  Click to read more

        //- Card 2 — Harshita Chavali
        .team-card(data-index='1')
          .team-photo-wrap
            img.team-photo(src='/images/team/harshita-chavali.png', alt='Harshita Chavali', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Harshita Chavali
            p.team-role Developer
          .team-hover
            h4 Harshita Chavali

        //- Card 3 — Kimi Tang
        .team-card(data-index='2')
          .team-photo-wrap
            img.team-photo(src='/images/team/kimi-tang.png', alt='Kimi Tang', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Kimi Tang
            p.team-role Developer
          .team-hover
            h4 Kimi Tang

        //- Card 4 — Eldridge Pacifico
        .team-card(data-index='3')
          .team-photo-wrap
            img.team-photo(src='/images/team/eldridge-pacifico.png', alt='Eldridge Pacifico', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Eldridge Pacifico
            p.team-role Developer
          .team-hover
            h4 Eldridge Pacifico

        //- Card 5 — Saira Abedi
        .team-card(data-index='4')
          .team-photo-wrap
            img.team-photo(src='/images/team/saira-abedi.png', alt='Saira Abedi', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Saira Abedi
            p.team-role Developer
          .team-hover
            h4 Saira Abedi

        //- Card 6 — Sienna Casule
        .team-card(data-index='5')
          .team-photo-wrap
            img.team-photo(src='/images/team/sienna-casule.png', alt='Sienna Casule', onerror="this.src='/images/team/placeholder.png'")
          .team-info
            h3.team-name Sienna Casule
            p.team-role Developer
          .team-hover
            h4 Sienna Casule

  //- ── TEAM MODAL ─────────────────────────────────────────────
  .team-modal-backdrop#teamModalBackdrop
    .team-modal#teamModal
      button.team-modal-close#teamModalClose(aria-label='Close')
        i.fa-solid.fa-xmark
      .team-modal-body
        .team-modal-photo-wrap
          img#teamModalPhoto(src='', alt='')
        .team-modal-text
          h2#teamModalName
          p.team-modal-role#teamModalRole
          p.team-modal-intro#teamModalIntro
          .team-modal-contribution
            h4
              i.fa-solid.fa-star
              |  Contribution
            p#teamModalContribution

  section.section
    .container
      h2.section-title Our Values
      .values-list
        .value-item
          .value-number 01
          .value-text
            h3 Accessibility
            p Everyone deserves access to food, regardless of circumstance or ability.
        .value-item
          .value-number 02
          .value-text
            h3 Community
            p We believe in the power of local communities to support one another.
        .value-item
          .value-number 03
          .value-text
            h3 Dignity
            p We provide support with compassion and respect for every individual.
        .value-item
          .value-number 04
          .value-text
            h3 Sustainability
            p We aim to reduce food waste and environmental impact in everything we do.

  script.
    // ── Team member data ────────────────────────────────────────
    // Fill in your own names, roles, intros, contributions, and photo paths here
    const teamMembers = [
      {
        name: 'Kurt Canillas',
        role: 'Developer',
        photo: '/images/team/kurt-canillas.png',
        intro: 'Computer Science student at the University of East Anglia. Passionate about full-stack web development and building applications that make a real difference in the community.',
        contribution: 'Led the overall architecture and development of the Feed Birmingham platform. Built the Locations page with interactive Leaflet map, implemented the postcode search with live radius filtering, and set up the Express/Pug project structure.'
      },
      {
        name: 'Harshita Chavali',
        role: 'Developer',
        photo: '/images/team/harshita-chavali.png',
        intro: 'Computer Science student at the University of East Anglia. Interested in UI/UX design and creating accessible, user-friendly web experiences.',
        contribution: 'Designed and implemented the Contact Us page including the FAQ accordion section and form validation. Contributed to the overall site styling and responsive layout across multiple pages.'
      },
      {
        name: 'Kimi Tang',
        role: 'Developer',
        photo: '/images/team/kimi-tang.png',
        intro: 'Computer Science student at the University of East Anglia. Enthusiastic about database design and back-end development for data-driven applications.',
        contribution: 'Worked on the database schema and PostgreSQL migrations. Implemented the food bank data models and contributed to the delivery request and tracking functionality.'
      },
      {
        name: 'Eldridge Pacifico',
        role: 'Developer',
        photo: '/images/team/eldridge-pacifico.png',
        intro: 'Computer Science student at the University of East Anglia. Focused on building robust and scalable web applications with clean, maintainable code.',
        contribution: 'Developed the Hot Meals Schedule page and Delivery Service pages. Implemented the delivery request form with postcode-based food bank search and the order tracking view with route mapping.'
      },
      {
        name: 'Saira Abedi',
        role: 'Developer',
        photo: '/images/team/saira-abedi.png',
        intro: 'Computer Science student at the University of East Anglia. Passionate about inclusive design and making technology accessible to diverse communities.',
        contribution: 'Built the Donate page including the card payment form with client-side validation and the donation success modal. Contributed to the multilingual support feature with Polish and Punjabi translations.'
      },
      {
        name: 'Sienna Casule',
        role: 'Developer',
        photo: '/images/team/sienna-casule.png',
        intro: 'Computer Science student at the University of East Anglia. Interested in the intersection of technology and social impact, particularly in community-focused applications.',
        contribution: 'Implemented the Food Education page and the About Us team section. Contributed to the settings page with language selection, theme toggling, and accessibility features including colour-blind mode and text-to-speech.'
      }
    ];

    // ── Modal logic ─────────────────────────────────────────────
    const backdrop = document.getElementById('teamModalBackdrop');
    const modal    = document.getElementById('teamModal');
    const closeBtn = document.getElementById('teamModalClose');
    const mPhoto   = document.getElementById('teamModalPhoto');
    const mName    = document.getElementById('teamModalName');
    const mRole    = document.getElementById('teamModalRole');
    const mIntro   = document.getElementById('teamModalIntro');
    const mContrib = document.getElementById('teamModalContribution');

    function openModal(index) {
      const m = teamMembers[index];
      mPhoto.src   = m.photo;
      mPhoto.onerror = () => { mPhoto.src = '/images/team/placeholder.png'; };
      mPhoto.alt   = m.name;
      mName.textContent    = m.name;
      mRole.textContent    = m.role;
      mIntro.textContent   = m.intro;
      mContrib.textContent = m.contribution;
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.team-card').forEach(card => {
      card.addEventListener('click', () => openModal(+card.dataset.index));
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', e => {
      if (e.target === backdrop) closeModal();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });
