extends layout

block content
  //- ── HERO ───────────────────────────────────────────────────
  section.hero
    .hero-overlay
    .hero-content
      h1 #{t('home.hero.title')}
      p.hero-subtitle
        | #{t('home.hero.subtitle')}
      .hero-actions
        if !isLoggedIn
          a.btn.btn-white(href='/register') #{t('common.signup')}
        a.btn.btn-outline-white(href='/locations') #{t('common.findbank')}

  //- ── QUICK LINKS ────────────────────────────────────────────
  section.section.quick-links-section
    .container
      .quick-links
        a.quick-link-card(href='/locations')
          i.fa-solid.fa-map-location-dot
          h3 #{t('home.quick.find')}
          p #{t('home.quick.find.sub')}
        a.quick-link-card(href='/delivery')
          i.fa-solid.fa-truck
          h3 #{t('home.quick.delivery')}
          p #{t('home.quick.delivery.sub')}
        a.quick-link-card(href='/donate')
          i.fa-solid.fa-hand-holding-heart
          h3 #{t('home.quick.donate')}
          p #{t('home.quick.donate.sub')}
        a.quick-link-card(href='/hot-meals')
          i.fa-solid.fa-utensils
          h3 #{t('home.quick.hotmeals')}
          p #{t('home.quick.hotmeals.sub')}

  //- ── HOT MEAL SCHEDULE (PREVIEW) ────────────────────────────
  section.section.meals-section
    .container
      .section-header
        h2 #{t('home.schedule.title')}
        a.btn.btn-outline-green(href='/hot-meals') #{t('common.viewfull')}
      .meals-table-wrap
        table.meals-table
          thead
            tr
              th #{t('common.day')}
              th #{t('common.location')}
              th #{t('common.time')}
              th #{t('common.spaces')}
          tbody
            tr
              td #{t('common.monday')}
              td Birmingham Central Food Bank
              td 12:00 – 14:00
              td.badge-available #{t('common.available')}
            tr
              td #{t('common.tuesday')}
              td Feeding Hands, Sparkhill
              td 11:30 – 13:30
              td.badge-limited #{t('common.limited')}
            tr
              td #{t('common.wednesday')}
              td Birmingham East Food Bank
              td 12:00 – 14:00
              td.badge-available #{t('common.available')}
            tr
              td #{t('common.thursday')}
              td St Anne's Community Hub
              td 13:00 – 15:00
              td.badge-full #{t('common.full')}
            tr
              td #{t('common.friday')}
              td Birmingham Central Food Bank
              td 11:00 – 13:00
              td.badge-available #{t('common.available')}

  //- ── ABOUT STRIP ────────────────────────────────────────────
  section.section.about-strip
    .container
      .about-strip-inner
        .about-text
          h2 #{t('home.about.title')}
          p #{t('home.about.body')}
          a.btn.btn-green(href='/about') #{t('common.learnmore')}
        .about-stats
          .stat
            span.stat-num 20+
            span.stat-label #{t('home.stat.banks')}
          .stat
            span.stat-num 500+
            span.stat-label #{t('home.stat.families')}
          .stat
            span.stat-num 7
            span.stat-label #{t('home.stat.days')}
