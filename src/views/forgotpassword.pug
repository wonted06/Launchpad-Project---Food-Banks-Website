//- -------------------------------------------------------
//- forgotpassword.pug - Forgot Password Page
//- -------------------------------------------------------

extends layout

block content
  section.auth-page
    .auth-card
      h1 Forgot Password
      p.auth-subtitle Enter your email to reset your FEED Birmingham password.

      form.form(action='/forgot-password' method='POST')
        .form-group
          label(for='email') Email
          input#email.input(
            type='email'
            name='email'
            placeholder='Enter your email'
            required
          )

        button.btn.btn-primary(type='submit') Send Reset Link

      if message
        p.auth-switch= message

      a.back-home(href='/login') ← Back to Login
