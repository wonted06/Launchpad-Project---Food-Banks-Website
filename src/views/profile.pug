section#section-profile.dash-section(aria-label='Profile', hidden)
  .profile-page
    .profile-card
      h1 Profile Page
      p.auth-subtitle Manage your account, security, and accessibility settings.

      if error
        p.error-message= error

      .profile-section
        h2 Account Details

        if user
          .profile-info
            .profile-avatar 👤
            .profile-text
              p
                strong Username:
                |  #{user.username}
              p
                strong Name:
                |  #{user.real_name}
              p
                strong Email:
                |  #{user.email}

          form.profile-form.dashboard-form(action='/profile/edit' method='POST')
            .form-row
              .form-group
                label(for='real_name') Name
                input#real_name(type='text' name='real_name' value=user.real_name required)

              .form-group
                label(for='email') Email
                input#email(type='email' name='email' value=user.email required)

            .form-row
              .form-group
                label(for='height_cm') Height (cm)
                input#height_cm(type='number' step='0.1' name='height_cm' value=user.height_cm)

              .form-group
                label(for='weight_kg') Weight (kg)
                input#weight_kg(type='number' step='0.1' name='weight_kg' value=user.weight_kg)

            .form-group
              label(for='age') Age
              input#age(type='number' name='age' value=user.age)

            button.btn.btn-primary(type='submit') Save Profile
        else
          p.empty-state No user loaded.

      .profile-section
        h2 Change Password

        form.profile-form.dashboard-form(action='/profile/change-password' method='POST')
          .form-row
            .form-group
              label(for='password') New password
              input#password(type='password' name='password' placeholder='Enter new password' required)

            .form-group
              label(for='password2') Confirm password
              input#password2(type='password' name='password2' placeholder='Re-enter password' required)

          button.btn.btn-secondary(type='submit') Change Password

      .profile-section
        h2 Accessibility

        .dashboard-form
          .form-row
            .form-group
              label(for='language') Language
              select#language(name='language')
                option English

            .form-group
              label(for='text-size') Text Size
              select#text-size(name='text-size')
                option Medium (Default)
                option Large
                option Extra Large

          .form-group
            label(for='theme') Theme
            select#theme(name='theme')
              option(value='light') Light (Default)
              option(value='dark') Dark

      .profile-actions
        a.btn.btn-primary(href='/dashboard') Back to Dashboard
        a.btn.btn-secondary(href='/logout') Log out