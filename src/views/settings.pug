extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 #{t('settings.hero.title')}
      p.page-subtitle #{t('settings.hero.subtitle')}

  section.section
    .container.container--narrow
      form.settings-form(action='/settings', method='POST')

        .settings-card
          h2
            i.fa-solid.fa-language
            |  #{t('settings.lang.title')}
          .settings-row
            .settings-label
              strong #{t('settings.lang.title')}
              p #{t('settings.lang.sub')}
            .settings-control
              select.settings-select(name='language')
                option(value='en', selected=settings.language==='en') English
                option(value='pl', selected=settings.language==='pl') Polski
                option(value='pu', selected=settings.language==='pu') ਪੰਜਾਬੀ
                option(value='ur', selected=settings.language==='ur') اردو
                option(value='bn', selected=settings.language==='bn') বাংলা
                option(value='ph', selected=settings.language==='ph') پہاڑی
          .settings-row
            .settings-label
              p.settings-coming-soon
                i.fa-solid.fa-clock
                |  Multi-language support coming soon.

        .settings-card
          h2
            i.fa-solid.fa-palette
            |  #{t('settings.appearance.title')}
          .settings-row
            .settings-label
              strong #{t('settings.theme.label')}
              p #{t('settings.theme.sub')}
            .settings-control
              .toggle-group
                input#theme-light(type='radio', name='theme', value='light', checked=settings.theme !== 'dark')
                label(for='theme-light')
                  i.fa-solid.fa-sun
                  |  #{t('settings.theme.light')}
                input#theme-dark(type='radio', name='theme', value='dark', checked=settings.theme === 'dark')
                label(for='theme-dark')
                  i.fa-solid.fa-moon
                  |  #{t('settings.theme.dark')}

          .settings-row
            .settings-label
              strong #{t('settings.size.label')}
              p #{t('settings.size.sub')}
            .settings-control
              .size-slider-wrap
                input#text-size(type='range', name='textSize', min='12', max='20', value=settings.textSize || 15, step='1')
                span.size-preview(id='size-value')= (settings.textSize || 15) + 'px'

        .settings-card
          h2
            i.fa-solid.fa-universal-access
            |  #{t('settings.access.title')}
          .settings-row
            .settings-label
              strong #{t('settings.cb.label')}
              p #{t('settings.cb.sub')}
            .settings-control
              label.toggle-switch
                input(type='checkbox', name='colourBlind', checked=settings.colourBlind)
                span.toggle-slider

          .settings-row
            .settings-label
              strong #{t('settings.tts.label')}
              p #{t('settings.tts.sub')}
            .settings-control
              label.toggle-switch
                input(type='checkbox', name='textToSpeech', checked=settings.textToSpeech)
                span.toggle-slider

        .settings-actions
          button.btn.btn-green(type='submit')
            i.fa-solid.fa-floppy-disk
            |  #{t('common.save')}

  script.
    // Live text-size preview — set root font-size so rem units scale site-wide
    const slider = document.getElementById('text-size');
    const preview = document.getElementById('size-value');
    slider.addEventListener('input', () => {
      preview.textContent = slider.value + 'px';
      document.documentElement.style.fontSize = slider.value + 'px';
    });

    // Live theme preview
    document.querySelectorAll('input[name="theme"]').forEach(function (radio) {
      radio.addEventListener('change', function () {
        document.body.dataset.theme = this.value;
      });
    });

    // Live colour blind preview
    const cbToggle = document.querySelector('input[name="colourBlind"]');
    cbToggle.addEventListener('change', function () {
      document.body.classList.toggle('colour-blind', this.checked);
    });

    // Live TTS preview — deferred because #tts-btn is rendered after this script
    document.addEventListener('DOMContentLoaded', function () {
      const ttsToggle = document.querySelector('input[name="textToSpeech"]');
      const ttsBtn = document.getElementById('tts-btn');
      if (!ttsToggle || !ttsBtn) return;
      ttsToggle.addEventListener('change', function () {
        ttsBtn.style.display = this.checked ? 'flex' : 'none';
      });
    });

    // On submit: also write to localStorage so guests and instant apply both work
    document.querySelector('.settings-form').addEventListener('submit', function () {
      const fd = new FormData(this);
      try {
        localStorage.setItem('fbSettings', JSON.stringify({
          theme:        fd.get('theme') || 'light',
          textSize:     parseInt(fd.get('textSize')) || 15,
          colourBlind:  !!fd.get('colourBlind'),
          textToSpeech: !!fd.get('textToSpeech'),
        }));
      } catch (_) {}
    });
