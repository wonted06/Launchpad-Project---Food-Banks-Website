extends layout

block content
  section.landing-hero
    .landing-card

      h1 Welcome to
        span  FEED Birmingham

      p.landing-subtitle
        | Connecting communities with food assistance across Birmingham.
        | Find your nearest food bank, request support, or get involved today.

      .landing-actions
        a.btn.btn-primary(href='/login') Login
        a.btn.btn-secondary(href='/register') Register

      ul.landing-features
        li Find food banks near you
        li Request food assistance
        li Donate food or funds
        li Volunteer opportunities
