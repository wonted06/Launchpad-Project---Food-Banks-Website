extends layout

block content
  section.page-hero.page-hero--short
    .container
      h1 Hot Meal Schedule
      p.page-subtitle Free hot meals available across Birmingham every week.

  section.section
    .container
      .meals-info-strip
        .meals-info-item
          i.fa-solid.fa-utensils
          p Free hot nutritious meals served weekly
        .meals-info-item
          i.fa-solid.fa-map-location-dot
          p Multiple locations across Birmingham
        .meals-info-item
          i.fa-solid.fa-users
          p Open to all Birmingham residents

      .meals-table-wrap
        table.meals-table.meals-table--full
          thead
            tr
              th Day
              th Food Bank / Location
              th Address
              th Time
              th Menu
              th Spaces
          tbody
            tr
              td Monday
              td Birmingham Central Food Bank
              td 123 Broad Street, B1 2AA
              td 12:00 – 14:00
              td Soup, Bread, Main, Dessert
              td.badge-available Available
            tr
              td Tuesday
              td Feeding Hands, Sparkhill
              td 78 Sparkhill Road, B11 4EJ
              td 11:30 – 13:30
              td Main Course, Drink
              td.badge-limited Limited
            tr
              td Wednesday
              td Birmingham East Food Bank
              td 45 Coventry Road, B10 0TP
              td 12:00 – 14:00
              td Soup, Main, Dessert
              td.badge-available Available
            tr
              td Thursday
              td St Anne's Community Hub
              td 12 College Road, B6 6JT
              td 13:00 – 15:00
              td Main Course, Dessert, Drink
              td.badge-full Full
            tr
              td Friday
              td Birmingham Central Food Bank
              td 123 Broad Street, B1 2AA
              td 11:00 – 13:00
              td Soup, Main, Dessert
              td.badge-available Available
            tr
              td Saturday
              td Feeding Hands, Sparkhill
              td 78 Sparkhill Road, B11 4EJ
              td 10:00 – 12:00
              td Brunch, Drink
              td.badge-available Available
            tr
              td Sunday
              td –
              td –
              td –
              td No service
              td –

      .meals-note
        i.fa-solid.fa-circle-info
        p
          | Spaces are allocated on a first-come, first-served basis.
          | No referral needed — just turn up. Spaces marked
          strong  Full
          |  cannot accommodate new arrivals on that day.
