# ---------------------------------------------------
# .env.example — Template for Environment Variables
# ----------------------------------------------------
# A template for the .env file that everyone should create locally
# This file (.env.example) IS committed to Git so other team members
# know what variables they need to set, without exposing real values
#
# SETUP: 
# 1) Create a copy of this file named ".env" in the same directory
# 2) Fill in the actual values for your database connection 
# ----------------------------------------------------

# --- PostgreSQL Database Settings ---
# These values tell Node.js how to connect to your local pgAdmin database
# Each team member will have different credentials here
DB_HOST=cmpstudb-01.cmp.uea.ac.uk # Should be emailed to you by UEA
DB_PORT=5432
DB_NAME=fjk23wtu # usually the same as your DB_USER
DB_USER=fjk23wtu # without "@uea.ac.uk"
DB_PASSWORD=spread-five-Pink-Home-_0042 # replace with your actual DB password (emailed to us by UEA)

# --- Session Secret ---
# A long random string used to sign session cookies
# Make this at least 32 characters. You can generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ed12ba4355c3ebcab5e0a7ace25bb65d78a7e59d87249146cc62fc7780ea2a37

# --- Server Port ---
# The port your server will run on locally
PORT=3000

